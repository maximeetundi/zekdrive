# Application
APP_ENV=development
APP_PORT=8080

# Database (PostgreSQL + PostGIS)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=zekdrive
DB_USER=zekdrive
DB_PASSWORD=zekdrive_secret_change_in_prod
DB_SSL_MODE=disable
POSTGRES_DB=zekdrive
POSTGRES_USER=zekdrive
POSTGRES_PASSWORD=zekdrive_secret_change_in_prod

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_prod
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend
NUXT_PUBLIC_API_URL=http://localhost/api/v1
NUXT_PUBLIC_WS_URL=ws://localhost/ws

# PgAdmin (dev only)
PGADMIN_EMAIL=admin@zekdrive.com
PGADMIN_PASSWORD=pgadmin_password

# Firebase (push notifications)
FIREBASE_CREDENTIALS_FILE=

# SMS (OTP)
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=ZekDrive
